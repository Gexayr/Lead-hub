# ─── App ──────────────────────────────────────────────────────────────────────
# Port exposed on the host machine (maps to container port 8080)
APP_PORT=3000

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=leadobsidian
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=leadobsidian

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
# Get your bot token from @BotFather on Telegram
TG_BOT_TOKEN=

# Your personal Telegram user ID (get it from @userinfobot on Telegram)
TG_CHAT_ID=
